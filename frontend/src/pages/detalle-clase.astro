---
import ClassDetail from '../components/ClassDetail.jsx';
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Detalle de Clase - Memoretos</title>
</head>
<body>
    <div class="main-container">
        <header class="logos-header">
            <div class="logo-container">
                <img src="https://uniconexed.org/wp-content/uploads/2022/03/Tec-de-Monterrey-logo-horizontal-blue.png" alt="Tec" class="logo-tec">
                <div class="divider"></div>
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRqgYZIRFwklAQqOAdsTuabq0FN_28MIONRPQ&s" alt="UNAE" class="logo-unae">
            </div>
        </header>

        <ClassDetail client:only="react" />
    </div>
</body>
</html>

<style>
    :root {
        --bg-start: #4b013e;
        --bg-end: #a450ba;
        --card-crema: #f1ede4;
        --text-table: #333;
    }

    body {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--bg-start) 0%, var(--bg-end) 100%);
        color: white;
        padding: 20px 50px;
        font-family: 'Segoe UI', sans-serif;
    }

    .logos-header {
        display: flex;
        justify-content: flex-end;
        margin-bottom: -40px; 
    }

    .logo-container { display: flex; align-items: center; gap: 15px; }
    .logo-tec { height: 35px; filter: brightness(0) invert(1); }
    .logo-unae { height: 55px; }
    .divider { width: 1px; height: 45px; background: rgba(255,255,255,0.3); }

    :global(.header-section) { margin-bottom: 20px; }
    :global(.title-row) { display: flex; align-items: center; gap: 15px; }
    :global(.back-arrow) { 
        text-decoration: none; 
        color: white; 
        font-size: 2.5rem; 
        cursor: pointer; 
    }
    :global(.title-group h1) { font-size: 3.5rem; font-weight: 300; margin: 0; }

    :global(.search-container) {
        background-color: var(--card-crema);
        border-radius: 12px;
        padding: 12px 25px;
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 20px;
    }

    :global(.search-input) {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        font-size: 1.1rem;
        color: #555;
    }

    :global(.card-style) {
        background-color: var(--card-crema);
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    :global(.table-section) {
        padding: 20px;
        max-height: 400px;
        overflow-y: auto;
    }

    :global(.data-table) {
        width: 100%;
        border-collapse: collapse;
        color: var(--text-table);
    }

    :global(.data-table th, .data-table td) {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid rgba(0,0,0,0.1);
    }

    :global(.action-bar) {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin: 15px 0;
    }

    :global(.export-btn) {
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        color: white;
        font-weight: bold;
        cursor: pointer;
        background-color: #a450ba;
    }

    :global(.charts-grid) {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-top: 20px;
    }

    :global(.chart-container) {
        height: 350px;
        padding: 15px;
    }

    @media print {
        :global(.back-arrow, .search-container, .action-bar) { display: none; }
        body { background: white; padding: 0; color: black; }
        :global(.card-style) { box-shadow: none; border: 1px solid #ddd; }
    }
</style>