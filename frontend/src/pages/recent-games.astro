---
import RecentGamesTable from '../components/RecentGamesTable.jsx';
---

<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Dashboard - Partidas Recientes</title>
</head>
<body>
    <div class="main-container">
        <header class="header-section">
            <div class="title-group">
                <div class="title-row">
                    <a href="/dashboard" class="back-arrow">←</a>
                    <h1>DASHBOARD</h1>
                </div>
                <p>Partidas recientes (Todas las clases)</p>
            </div>

            <div class="logo-container">
                <img src="https://uniconexed.org/wp-content/uploads/2022/03/Tec-de-Monterrey-logo-horizontal-blue.png" alt="Tec" class="logo-tec">
                <div class="divider"></div>
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRqgYZIRFwklAQqOAdsTuabq0FN_28MIONRPQ&s" alt="UNAE" class="logo-unae">
            </div>
        </header>

        <RecentGamesTable client:load />
    </div>
</body>
</html>

<style>
    :root {
        --dark-purple: #4b013e;
        --light-purple: #a450ba;
        --bg-crema: #f1ede4;    
        --text-dark: #333;
    }

    body {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--dark-purple) 0%, var(--light-purple) 100%);
        color: white;
        margin: 0;
        padding: 40px;
        font-family: 'Segoe UI', sans-serif;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .title-row { display: flex; align-items: center; gap: 20px; }
    .title-group h1 { font-size: 3.5rem; font-weight: 300; margin: 0; }
    .title-group p { font-size: 1.5rem; opacity: 0.9; margin-left: 70px; margin-top: -10px; }

    .back-arrow {
        text-decoration: none;
        color: white;
        font-size: 3rem;
        cursor: pointer;
    }

    :global(.search-input) {
        width: 100%;
        padding: 15px 25px;
        border-radius: 15px;
        border: none;
        background-color: var(--bg-crema);
        font-style: italic;
        font-size: 1.1rem;
        color: var(--text-dark);
        margin-bottom: 25px;
        outline: none;
    }

    :global(.card-style) {
        background-color: var(--bg-crema);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    :global(.recent-table) {
        width: 100%;
        border-collapse: collapse;
        color: var(--text-dark);
    }

    :global(.recent-table th) {
        font-style: italic;
        padding-bottom: 15px;
        border-bottom: 1px solid rgba(0,0,0,0.1);
        text-align: left;
    }

    :global(.recent-table td) {
        padding: 12px 0;
        font-style: italic;
    }

    :global(.export-footer) {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 20px;
        margin-top: 30px;
    }

    :global(.btn-export) {
        border: none;
        padding: 12px 40px;
        border-radius: 10px;
        color: white;
        font-weight: bold;
        cursor: pointer;
        background-color: #a450ba;
        transition: 0.3s;
    }

    :global(.btn-export:hover) {
        background-color: var(--dark-purple);
    }

    .logo-container { display: flex; align-items: center; gap: 15px; }
    .logo-tec { height: 35px; filter: brightness(0) invert(1); }
    .logo-unae { height: 55px; }
    .divider { width: 1px; height: 40px; background: rgba(255,255,255,0.3); }

    @media print {
        .back-arrow, :global(.search-section), :global(.export-footer) { display: none; }
        body { background: white; padding: 20px; color: black; }
        :global(.card-style) { box-shadow: none; border: 1px solid #ccc; }
    }
</style>